<script>
(function() {
  var KB = [
    { tags: ['what','keres','company','about','who','does','do'], answer: "Keres AI is a boutique AI automation studio based in the USA. We design and deploy custom AI Agents that handle repetitive, time-consuming tasks — saving businesses an average of 70% of manual work time and cutting costs significantly." },
    { tags: ['agents','agent','services','types','offer','build','make','kind'], answer: "We build three core types of AI Agents:\n\n📧 AI Email & Support Agent — auto-reads and responds to emails and support tickets.\n📊 Automated Reporting Agent — pulls data and delivers formatted reports on schedule.\n🎯 Lead Qualification Agent — scores inbound leads and routes the best ones to your sales team.\n\nWe also build fully custom agents for unique workflows!" },
    { tags: ['email','support','ticket','inbox','customer'], answer: "Our AI Email & Support Agent reads every inbound email or ticket, categorises it, and responds automatically — cutting response times from hours to seconds. It works with Gmail, Outlook, Zendesk, and most major platforms." },
    { tags: ['report','reporting','data','analytics','insights'], answer: "Our Automated Reporting Agent pulls from your tools — spreadsheets, CRMs, ad platforms — and delivers clean reports on schedule. No analyst, no manual work, no delays." },
    { tags: ['lead','leads','sales','qualify','crm','pipeline'], answer: "Our Lead Qualification Agent scores inbound leads, enriches their profiles, and routes only the highest-quality ones to your sales team — so your team spends time on deals that actually close." },
    { tags: ['long','timeline','weeks','deploy','launch','fast','quick'], answer: "Most agents are scoped, built, tested, and live within 2–4 weeks. We handle everything — there's no bottleneck on your side." },
    { tags: ['price','pricing','cost','much','fee','charge','expensive','budget'], answer: "Pricing is custom to your scope. The best way to get a number is to book a free 30-minute discovery call — we'll scope it together with no obligation." },
    { tags: ['roi','return','save','saving','money','worth','results','impact'], answer: "Our clients average a 5× ROI and 70% reduction in manual work time. One client recovered 12 hours per week — paying back the investment in the first month." },
    { tags: ['technical','tech','developer','coding','team','setup'], answer: "No technical team needed at all. We handle scoping, building, testing, deploying, and integrating with your existing stack — you just tell us what's slowing you down." },
    { tags: ['tools','integrate','slack','gmail','hubspot','salesforce','zapier','existing'], answer: "We integrate with Gmail, Outlook, Slack, HubSpot, Salesforce, Notion, Airtable, Google Sheets, and many more. If you use it, chances are we can connect to it." },
    { tags: ['book','call','meeting','schedule','calendly','discovery','talk','speak'], answer: "Book a free 30-minute discovery call using the calendar on this page — scroll to 'Let's Connect' and pick a date. It opens our booking page to choose your time. No cost, no commitment. You can also go directly to calendly.com/ops-keresai/30min" },
    { tags: ['contact','message','reach','touch','form','send'], answer: "Use the contact form on this page — scroll to 'Let's Connect'. We respond within 24 hours. Or book a call right there using the calendar next to the form." },
    { tags: ['clients','projects','deployed','experience','record'], answer: "We've deployed 40+ AI agents across many industries. Our client retention is 97% — most clients return for a second agent after seeing the results." },
    { tags: ['usa','america','location','where','based','country'], answer: "Keres AI is based in the USA, serving businesses nationwide. We work fully remotely and have partnered with companies across the country." },
    { tags: ['custom','bespoke','unique','specific','tailored'], answer: "Every agent is 100% custom-built. No templates, no off-the-shelf software. We engineer each agent around your exact workflows, tools, and goals." },
    { tags: ['why','different','competitor','versus','compare','choose'], answer: "We build precision-engineered agents for your exact workflow — not generic tools. Every agent is held to real ROI and time-saving metrics. We don't ship demos. We ship results." },
    { tags: ['hi','hello','hey','morning','afternoon','greetings'], answer: "Hey there! 👋 I'm the Keres AI assistant. Ask me anything about what we do, our agents, pricing, timelines, or how to get started!" },
    { tags: ['thanks','thank','cheers','appreciate','helpful'], answer: "You're very welcome! 😊 If you have more questions or want to explore what an AI agent could do for you, just ask — or book a free call on this page." }
  ];

  var FALLBACK = "Great question! I don't have a specific answer for that, but our team would love to help. Use the contact form on this page or book a free discovery call — we respond within 24 hours. 🙌";

  function ragAnswer(query) {
    var q = query.toLowerCase().replace(/[^a-z0-9 ]/g, ' ');
    var words = q.split(/\s+/).filter(Boolean);
    var best = 0, answer = null;
    for (var i = 0; i < KB.length; i++) {
      var score = 0;
      for (var j = 0; j < words.length; j++) {
        for (var k = 0; k < KB[i].tags.length; k++) {
          if (KB[i].tags[k] === words[j] || words[j].indexOf(KB[i].tags[k]) > -1 || KB[i].tags[k].indexOf(words[j]) > -1) { score++; break; }
        }
      }
      if (score > best) { best = score; answer = KB[i].answer; }
    }
    return best > 0 ? answer : FALLBACK;
  }

  var chatOpen = false, hasGreeted = false;
  var chatBtn = document.getElementById('chat-btn');
  var chatBox = document.getElementById('chat-box');
  var chatMessages = document.getElementById('chat-messages');
  var chatInput = document.getElementById('chat-input');
  var chatSend = document.getElementById('chat-send');
  var chatClose = document.getElementById('chat-close');
  var chatBadge = document.getElementById('chat-badge');

  function toggleChat() {
    chatOpen = !chatOpen;
    chatBox.style.display = chatOpen ? 'flex' : 'none';
    chatBtn.setAttribute('aria-expanded', chatOpen);
    chatBadge.style.display = 'none';
    if (chatOpen && !hasGreeted) {
      hasGreeted = true;
      setTimeout(function() { addMessage('bot', "Hi! 👋 I'm the Keres AI assistant. Ask me anything about what we do, our agents, pricing, or timelines — I'm here to help!"); }, 350);
    }
    if (chatOpen) setTimeout(function() { chatInput.focus(); }, 100);
  }

  function addMessage(role, text) {
    var wrap = document.createElement('div');
    wrap.className = 'cm-wrap cm-' + role;
    var bubble = document.createElement('div');
    bubble.className = 'cm-bubble';
    bubble.textContent = text;
    wrap.appendChild(bubble);
    chatMessages.appendChild(wrap);
    chatMessages.scrollTop = chatMessages.scrollHeight;
  }

  function addTyping() {
    var wrap = document.createElement('div');
    wrap.className = 'cm-wrap cm-bot';
    wrap.id = 'cm-typing';
    wrap.innerHTML = '<div class="cm-bubble cm-typing"><span></span><span></span><span></span></div>';
    chatMessages.appendChild(wrap);
    chatMessages.scrollTop = chatMessages.scrollHeight;
    return wrap;
  }

  function sendMessage() {
    var text = chatInput.value.trim();
    if (!text) return;
    chatInput.value = '';
    addMessage('user', text);
    var typing = addTyping();
    var delay = 500 + Math.random() * 600;
    setTimeout(function() { typing.remove(); addMessage('bot', ragAnswer(text)); }, delay);
  }

  chatBtn.addEventListener('click', toggleChat);
  chatClose.addEventListener('click', toggleChat);
  chatSend.addEventListener('click', sendMessage);
  chatInput.addEventListener('keydown', function(e) { if (e.key === 'Enter') { e.preventDefault(); sendMessage(); } });
  setTimeout(function() { if (!chatOpen) chatBadge.style.display = 'flex'; }, 4000);

  var suggestions = document.querySelectorAll('.chat-suggestion');
  for (var i = 0; i < suggestions.length; i++) {
    (function(btn) {
      btn.addEventListener('click', function() {
        if (!chatOpen) { toggleChat(); setTimeout(function() { chatInput.value = btn.textContent; sendMessage(); }, 450); }
        else { chatInput.value = btn.textContent; sendMessage(); }
      });
    })(suggestions[i]);
  }
})();
</script>
